# LLM Gateway (required)
# OpenRouter (recommended default)
LLM_GATEWAY_BASE_URL=https://openrouter.ai/api
LLM_GATEWAY_API_KEY=your-api-key-here

# Qdrant (optional, defaults to http://localhost:6333)
AUTOTEXT2SQL_QDRANT_URL=http://localhost:6333

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=your-langsmith-key
# AUTOTEXT2SQL_ENABLE_LANGSMITH=true

# Mem0 OSS reuses the same OpenAI-compatible gateway credentials above.
